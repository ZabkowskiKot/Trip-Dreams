# Local development environment variables
# Copy this file to .env and fill in real values for local testing.

BASE_URL=http://127.0.0.1:8001
SESSION_SECRET=super-secret-local-key
USE_FIRESTORE=false

# Uncomment and fill in your Google OAuth values when ready.
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# If you want to enable Firestore locally, set USE_FIRESTORE=true and provide credentials below.
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# FIRESTORE_PROJECT_ID=
